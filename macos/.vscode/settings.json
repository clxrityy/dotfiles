    "*.jar": "default",
    "*.db": "default",
    "*.VSIXPackage": "default",
    "*.xls": "default"
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false,
    "perl": false,
    "json": true,
  },
  "github.copilot.advanced": {
    "autoTrigger": {
      "enabled": true,
    },
    "inlayHints": {
      "enabled": true,
    },
    "debugLog": {
      "enabled": true,
    },
    "experimental": {
      "autoTriggerInlineSuggestions": {
        "enabled": true,
      },
    },
    "chat": {
      "enabled": true,
    },
    "inEditor": {
      "enabled": true,
    },
    "inEditor.autoTriggerDelayMs": 100,
  },
