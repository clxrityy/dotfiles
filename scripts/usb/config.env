#!/usr/bin/env bash
# ============================================================
#  config.env — USB Drive Partition Configuration
#  Edit this file before running setup_usb.sh
# ============================================================

# ---- Target Device ------------------------------------------
# Set to your USB device path (e.g. /dev/sdb, /dev/sdc).
# Leave empty to be prompted interactively.
USB_DEVICE=""

# ---- Partition Sizes (GiB) ----------------------------------
# Ventoy ISO storage partition (where you drop .iso files).
VENTOY_DATA_GiB=300

# Persistent portable OS (e.g. a live distro's casper-rw,
# or a full OS installation). Uses Linux filesystem.
PERSISTENT_GiB=150

# Backup OS (recovery environment, secondary OS, etc.).
BACKUP_GiB=150

# DATA partition gets all remaining space automatically.

# ---- Filesystems --------------------------------------------
# Persistent OS partition filesystem.
# Options: ext4 (default), btrfs
PERSISTENT_FS="ext4"

# Backup OS partition filesystem.
# Options: ext4 (default), btrfs, ntfs (for Windows-based backup)
BACKUP_FS="ext4"

# Data partition filesystem.
# Options: exfat (default, cross-platform), ntfs, fat32, ext4
DATA_FS="exfat"

# ---- Partition Labels ---------------------------------------
VENTOY_LABEL="VENTOY"
PERSISTENT_LABEL="PERSISTENT"
BACKUP_LABEL="BACKUP_OS"
DATA_LABEL="USB_DATA"

# ---- Ventoy Settings ----------------------------------------
# "auto" = fetch the latest release from GitHub.
# Or pin a version, e.g. "1.0.99"
VENTOY_VERSION="auto"

# Where to download/extract Ventoy before installing.
VENTOY_DOWNLOAD_DIR="/tmp/ventoy_setup"

# ---- Safety -------------------------------------------------
# Set to 1 to skip all confirmation prompts (dangerous!).
# Can also be overridden with -f flag on the command line.
FORCE=0