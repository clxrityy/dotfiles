#!/usr/bin/env bash
# scripts/tests/run-tests.sh
#
# Run all test files in scripts/tests/.
# Exit code: 0 if all pass, 1 if any fail.
#
# Usage:
#   ./scripts/tests/run-tests.sh           # Run all tests
#   ./scripts/tests/run-tests.sh test_args  # Run specific test file

set -uo pipefail

TESTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
overall_exit=0

if [[ $# -gt 0 ]]; then
  # Run specific test files passed as arguments
  files=()
  for name in "$@"; do
    # Allow both "test_args" and "test_args.sh"
    [[ "$name" != *.sh ]] && name="${name}.sh"
    files+=("$TESTS_DIR/$name")
  done
else
  # Run all test_*.sh files
  files=()
  while IFS= read -r -d '' f; do
    files+=("$f")
  done < <(find "$TESTS_DIR" -maxdepth 1 -name 'test_*.sh' -print0 | sort -z)
fi

for test_file in "${files[@]}"; do
  if [[ ! -f "$test_file" ]]; then
    printf '[ERROR] Test file not found: %s\n' "$test_file"
    overall_exit=1
    continue
  fi

  printf '\n========== %s ==========\n' "$(basename "$test_file")"

  # Run each test file in a subshell so one failure doesn't kill the runner
  # `set -e` is NOT used here intentionally -- we want all tests to run
  if bash "$test_file"; then
    : # passed
  else
    overall_exit=1
  fi
done

printf '\n'
if [[ "$overall_exit" -eq 0 ]]; then
  printf '=== ALL TEST SUITES PASSED ===\n'
else
  printf '=== SOME TESTS FAILED ===\n'
fi

exit "$overall_exit"
