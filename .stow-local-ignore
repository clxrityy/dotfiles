# This file specifies patterns for files and directories to be ignored by GNU Stow
# ------------------------------

# Comments and blank lines are allowed

RCS
.+,v

CVS
\.\#.+       # CVS conflict files / emacs lock files
\.cvsignore

\.svn
_darcs
\.hg

\.git
\.gitignore
\.gitmodules

.+~          # emacs backup files
\#.*\#       # emacs autosave files

^/README.*
^/LICENSE.*
^/COPYING

# Ignore standard user folders
/Desktop
/Documents
/Downloads
/Music
/Pictures
/Videos
/Templates
/Public
/Library
/Applications
/Movies

# Ignore user-specific and system files
/.config
/.local
/.cache
/.CFUserTextEncoding
/.zsh_history
/.bash_history
/.lmstudio*
/.vscode
/.zsh_sessions
/.DS_Store
/.Trash

# Ignore script files
install.sh
.macos
.osx
Brewfile

# Ignore utility files
.markdownlint.json
